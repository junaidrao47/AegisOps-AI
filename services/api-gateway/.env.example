# API Gateway
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/aegisops
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ISSUER=aegisops
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Incident workspace
# Where uploaded incident artifacts are stored (local dev default)
INCIDENT_STORAGE_PATH=./.data/incidents
# 25MB default
MAX_UPLOAD_BYTES=26214400

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
